{
  "name": "@codenexus/app",
  "productName": "CodeNexus",
  "version": "1.0.1",
  "private": true,
  "description": "Unofficial Codex desktop GUI for Windows",
  "author": "CodeNexus contributors",
  "license": "MIT",
  "main": "dist/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/build.mjs",
    "lint": "pnpm exec eslint . --ext .ts,.vue,.mjs --max-warnings=0",
    "format": "pnpm exec prettier --ignore-path .prettierignore --write .",
    "format:check": "pnpm exec prettier --ignore-path .prettierignore --check .",
    "typecheck": "pnpm exec tsc --noEmit",
    "ci": "pnpm run format:check && pnpm run lint && pnpm run typecheck && pnpm run build",
    "codex:types": "npx -y @openai/codex@0.135.0 app-server generate-ts --experimental --out .\\\\tmp\\\\codex_0.135.0_generated",
    "dist": "pnpm run build && pnpm exec electron-builder --config electron-builder.yml"
  },
  "dependencies": {
    "@codenexus/generated": "workspace:*",
    "@codenexus/feature-flowchart": "workspace:*",
    "@codenexus/feature-imagegen": "workspace:*",
    "@codenexus/feature-paper": "workspace:*",
    "@codenexus/shared": "workspace:*",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@iconify/icons-vscode-icons": "^1.2.29",
    "@iconify/vue": "^5.0.0",
    "@lezer/highlight": "^1.2.3",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.5",
    "electron-updater": "^6.8.3",
    "html-to-image": "^1.11.13",
    "lucide-vue-next": "^0.574.0",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.15.0",
    "pinia": "^3.0.4",
    "shiki": "^4.0.1",
    "vue": "^3.5.28",
    "vue-i18n": "^11.4.4"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/compiler-sfc": "^3.5.28",
    "autoprefixer": "^10.4.27",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.1",
    "eslint-plugin-unused-imports": "^4.2.0",
    "eslint-plugin-vue": "^9.33.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.10",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^7.3.2",
    "vue-eslint-parser": "^9.4.3"
  }
}
