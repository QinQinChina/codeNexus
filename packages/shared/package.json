{
  "name": "@codenexus/shared",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./agent-protocol": "./src/agent-protocol/index.ts",
    "./agent-protocol/*": "./src/agent-protocol/*.ts",
    "./codex-protocol": "./src/codex-protocol/index.ts",
